# Portal Pantry API — copy to `.env` and adjust as needed.
# Every variable is optional; these are the defaults.

# Where the HTTP server listens. Use HOST=0.0.0.0 to expose on your LAN.
PORT=4000
HOST=127.0.0.1

# SQLite database file. Created (and seeded) on first boot. ":memory:" works too.
DATABASE_PATH=data/portal-pantry.sqlite

# Comma-separated list of allowed browser origins (the Vite dev server, by default).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# How long a login session stays valid, in hours (default: 30 days).
SESSION_TTL_HOURS=720

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Set to true only when running behind a reverse proxy that sets X-Forwarded-For.
TRUST_PROXY=false

{
  "name": "portal-pantry-back",
  "version": "1.0.0",
  "description": "Real Node.js backend for Portal Pantry — interdimensional food delivery. Express 5 + TypeScript + node:sqlite.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "pino": "^9.13.1",
    "pino-http": "^10.4.0",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.13.2",
    "@types/supertest": "^6.0.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "pino-pretty": "^13.1.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.4"
  }
}
